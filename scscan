#!/bin/bash

VERSION="1.0.3"

INTERFACE="${INTERFACE:-}"
BASE_PORT="${BASE_PORT:-50000}"
REMOTE_PORT="${REMOTE_PORT:-443}"
SSH_USER="${SSH_USER:-root}"
SSH_HOST="${SSH_HOST:-localhost}"

DB_FILE="${DB_FILE:-/usr/local/share/scscan/askey_oui.db}"
PID_FILE="/tmp/scscan.pid"
PORT_FILE="/tmp/scscan.ports"

show_help() {
cat <<EOF
scscan v$VERSION
Askey Small Cell Discovery Tool

Usage:
    $(basename "$0") [OPTIONS]

Options:
    -h, --help          Show help
    -v, --version       Show version
    -u, --update-db     Update Askey OUI database
    -s, --stop          Stop previous scscan tunnels

Environment:
    INTERFACE           Network interface
    BASE_PORT           Local tunnel start port, default: 50000
    REMOTE_PORT         Remote HTTPS port, default: 443
    SSH_USER            SSH username, default: root
    SSH_HOST            SSH target, default: localhost

Examples:
    $(basename "$0")
    $(basename "$0") -u
    $(basename "$0") -s
    INTERFACE=bridge0 $(basename "$0")
EOF
}

select_interface() {
    if [ -n "$INTERFACE" ]; then
        return
    fi

    mapfile -t IFACES < <(
        ip -o link show | awk -F': ' '{print $2}' | grep -v '^lo$'
    )

    if [ ${#IFACES[@]} -eq 0 ]; then
        echo "No network interface found."
        exit 1
    fi

    echo
    echo "Available Interfaces"
    echo

    for i in "${!IFACES[@]}"; do
        iface="${IFACES[$i]}"
        ipv4=$(ip -4 -o addr show dev "$iface" | awk '{print $4}' | paste -sd "," -)
        [ -z "$ipv4" ] && ipv4="No IPv4"
        echo "$((i+1))) $iface    $ipv4"
    done

    echo

    if [ ${#IFACES[@]} -eq 1 ]; then
        INTERFACE="${IFACES[0]}"
        echo "Using Interface : $INTERFACE"
        return
    fi

    while true; do
        read -p "Select Interface: " n

        if [[ "$n" =~ ^[0-9]+$ ]] &&
           [ "$n" -ge 1 ] &&
           [ "$n" -le "${#IFACES[@]}" ]; then
            INTERFACE="${IFACES[$((n-1))]}"
            break
        fi

        echo "Invalid selection."
    done

    echo
    echo "Using Interface : $INTERFACE"
}

