update_db() {
    echo "Updating Askey OUI DB..."

    if [ "$(id -u)" -ne 0 ] && [[ "$DB_FILE" == /usr/local/share/* ]]; then
        cat <<EOF

Error: administrator privilege required.

Database:
    $DB_FILE

Please run:

    sudo /usr/local/bin/scscan -u

EOF
        exit 1
    fi

    mkdir -p "$(dirname "$DB_FILE")" 2>/dev/null

    curl -L -s https://maclookup.app/vendors/askey-computer-corp \
    | grep -Eo '([A-Fa-f0-9]{2}:){2}[A-Fa-f0-9]{2}' \
    | tr '[:lower:]' '[:upper:]' \
    | sort -u > "$DB_FILE"

    if [ ! -s "$DB_FILE" ]; then
        echo "Update failed. Creating default DB."
        create_default_db
    fi

    chmod 644 "$DB_FILE" 2>/dev/null

    echo "DB updated: $DB_FILE"
    echo "Total OUI: $(wc -l < "$DB_FILE")"
    exit 0
}

cleanup_old() {
    if [ -f "$PID_FILE" ]; then
        echo "Cleaning previous scscan tunnels..."

        while read -r pid; do
            [ -n "$pid" ] && kill "$pid" 2>/dev/null
        done < "$PID_FILE"

        rm -f "$PID_FILE" "$PORT_FILE"
    fi
}

cleanup() {
    echo
    echo "Closing tunnels..."

    if [ -f "$PID_FILE" ]; then
        while read -r pid; do
            [ -n "$pid" ] && kill "$pid" 2>/dev/null
        done < "$PID_FILE"
    fi

    rm -f "$PID_FILE" "$PORT_FILE"
    echo "Done."
    exit 0
}

is_askey() {
    local oui
    oui=$(echo "$1" | tr '[:lower:]' '[:upper:]' | cut -c1-8)
    grep -qx "$oui" "$DB_FILE"
}

port_used() {
    ss -ltn | awk '{print $4}' | grep -q ":$1$"
}

next_port() {
    local port="$1"

    while port_used "$port"; do
        port=$((port + 1))
    done

    echo "$port"
}

show_header() {
    clear
    echo "=============================================================="
    echo "              scscan v$VERSION"
    echo "        Askey Small Cell Discovery Tool"
    echo "=============================================================="
    echo
    echo "Interface : $INTERFACE"
    echo "Base Port : $BASE_PORT"
    echo "Remote    : HTTPS $REMOTE_PORT"
    echo "OUI DB    : $DB_FILE ($(wc -l < "$DB_FILE") entries)"
    echo
}

case "$1" in
    -h|--help)
        show_help
        exit 0
        ;;
    -v|--version)
        echo "scscan v$VERSION"
        exit 0
        ;;
    -u|--update-db)
        update_db
        ;;
    -s|--stop|stop)
        cleanup_old
        echo "Stopped previous scscan tunnels."
        exit 0
        ;;
    "")
        ;;
    *)
        echo "Unknown option: $1"
        echo
        show_help
        exit 1
        ;;
esac

if [ ! -f "$DB_FILE" ]; then
    if [ "$(id -u)" -ne 0 ] && [[ "$DB_FILE" == /usr/local/share/* ]]; then
        cat <<EOF

Error: Askey OUI database not found.

Database:
    $DB_FILE

Initialize it once as administrator:

    sudo /usr/local/bin/scscan -u

EOF
        exit 1
    fi

    create_default_db
fi

trap cleanup INT TERM

cleanup_old
select_interface
show_header

echo "Scanning IPv6 neighbors..."
ping6 -c 3 -I "$INTERFACE" ff02::1 >/dev/null 2>&1

ASKEY_LIST=()

while read -r line; do
    ipv6=$(echo "$line" | awk '{print $1}')
    mac=$(echo "$line" | awk '{for(i=1;i<=NF;i++) if($i=="lladdr") print $(i+1)}')
    state=$(echo "$line" | awk '{print $NF}')

    if is_askey "$mac"; then
        ASKEY_LIST+=("$ipv6|$mac|$state")
    fi
done < <(
    ip -6 neighbor show dev "$INTERFACE" \
    | awk '/lladdr/ && /(REACHABLE|STALE|DELAY|PROBE|router)/ {print}'
)

if [ ${#ASKEY_LIST[@]} -eq 0 ]; then
    echo
    echo "No Askey device found."
    exit 1
fi

PORT="$BASE_PORT"
RESULTS=()

for item in "${ASKEY_LIST[@]}"; do
    PORT=$(next_port "$PORT")
    RESULTS+=("$PORT|$item")
    PORT=$((PORT + 1))
done

echo
echo "Found ${#RESULTS[@]} Askey device(s)."
echo

printf "%-4s %-8s %-42s %-18s %-10s\n" \
"No." "Port" "IPv6" "MAC" "State"

printf "%-4s %-8s %-42s %-18s %-10s\n" \
"---" "------" "----------------------------------------" "-----------------" "----------"

for i in "${!RESULTS[@]}"; do
    IFS='|' read -r port ipv6 mac state <<< "${RESULTS[$i]}"
    printf "%-4s %-8s %-42s %-18s %-10s\n" \
    "$((i+1))" "$port" "$ipv6" "$mac" "$state"
done

echo
echo "Creating tunnels..."

: > "$PID_FILE"
: > "$PORT_FILE"

for item in "${RESULTS[@]}"; do
    IFS='|' read -r port ipv6 mac state <<< "$item"

    ssh -N -f \
    -o StrictHostKeyChecking=no \
    -o UserKnownHostsFile=/dev/null \
    -o LogLevel=ERROR \
    -o ExitOnForwardFailure=yes \
    -o ServerAliveInterval=30 \
    -L "$port:[$ipv6%$INTERFACE]:$REMOTE_PORT" \
    "$SSH_USER@$SSH_HOST"

    if [ $? -eq 0 ]; then
        pid=$(pgrep -n -f "ssh.*$port:.*$ipv6")
        echo "$pid" >> "$PID_FILE"
        echo "$port|$ipv6|$mac|$state" >> "$PORT_FILE"
        echo "✓ localhost:$port -> $mac"
    else
        echo "✗ failed: $mac"
    fi
done

echo
echo "=============================================================="
echo "Open Browser"
echo "=============================================================="

while IFS='|' read -r port ipv6 mac state; do
    echo "$mac  https://localhost:$port"
done < "$PORT_FILE"

echo
echo "Ctrl+C to close all tunnels."
echo

while true; do
    sleep 1
done
